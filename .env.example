# Tracing/log level (RUST_LOG). If unset, defaults to "info".
# Examples: "debug", "oxigate=trace", "info"
RUST_LOG=info

# Docker / runtime env var overrides (OXIGATE__ prefix convention)
OXIGATE__SERVER__PORT=8080
OXIGATE__DATABASE__URL=postgres://oxigate:changeme@localhost:5432/oxigate
OXIGATE__REDIS__URL=redis://localhost:6379
OXIGATE__LOG_LEVEL=info

# Config-based auth (optional for dev; required for production)
# When set, all /v1/* requests must carry: Authorization: Bearer <value>
# When absent, auth is bypassed with a startup WARN (local dev / CI)
# OXIGATE__AUTH__KEY=your-secret-token-here

# Anthropic provider — use env to avoid putting the key in config YAML:
# OXIGATE__PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...
# OXIGATE__PROVIDERS__ANTHROPIC__DEFAULT_MAX_TOKENS=4096  # Anthropic requires max_tokens on every request
# OXIGATE__PROVIDERS__ANTHROPIC__TOOL_CALL_BUFFER_CAP_BYTES=1048576  # max streaming tool-arg buffer (default 1 MiB)
#
# Gemini provider — use env to avoid putting the key in config YAML:
# OXIGATE__PROVIDERS__GEMINI__MODE=api
# OXIGATE__PROVIDERS__GEMINI__API_KEY=your-google-key

# OpenAI-compatible providers — add each as an openai_compat[] entry in config YAML.
# Keys are passed via env so they never appear in YAML files committed to version control.
#
# Mistral
# MISTRAL_API_KEY=your-mistral-key
#
# Groq
# GROQ_API_KEY=your-groq-key
#
# Together AI
# TOGETHER_API_KEY=your-together-key
#
# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-key
#
# xAI (Grok)
# XAI_API_KEY=your-xai-key
#
# Cerebras
# CEREBRAS_API_KEY=your-cerebras-key

# Budget period reset. Omit for legacy unprefixed Redis keys.
# OXIGATE__BUDGET__BUDGET_DURATION=1mo   # 1d | 7d | 30d | 1mo
# OXIGATE__BUDGET__TIMEZONE=UTC          # IANA name, e.g. US/Eastern
# Postgres seed lower bound + explicit reset overrides period suffixes.
# Do not set BUDGET_RESET_AT together with BUDGET_DURATION — startup validation rejects it.
# OXIGATE__BUDGET__BUDGET_RESET_AT=2026-03-01T00:00:00Z
# Legacy YAML/env key still accepted: period_start (serde alias)
# Pro: background scheduler interval (seconds)
# OXIGATE__BUDGET__SCHEDULER_INTERVAL_SECS=60
